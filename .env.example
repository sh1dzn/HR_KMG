# HR AI Module Configuration

# PostgreSQL
POSTGRES_USER=hr_user
POSTGRES_PASSWORD=change_me
POSTGRES_DB=mock_smart
POSTGRES_PORT=5433

# Local connection string for direct host access
DATABASE_URL=postgresql://hr_user:change_me@127.0.0.1:5433/mock_smart

# OpenAI
# Leave empty if you only want to run the app without full LLM features
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic (optional)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION_NAME=vnd_documents

# Application
DEBUG=true
APP_NAME=HR AI Module
APP_VERSION=1.0.0

# Authentication
# Must be a strong random secret (at least 32 characters)
JWT_SECRET_KEY=

# Password used by backend/scripts/seed_users.py
# Set a strong temporary value and rotate after first login
DEFAULT_SEED_PASSWORD=
ADMIN_EMPLOYEE_IDS=

# Public remote MCP (HTTP JSON-RPC)
# Enable only if backend is reachable from internet and protected by TLS.
MCP_PUBLIC_ENABLED=false
# Optional shared token for Authorization: Bearer <token> or X-MCP-Key header
MCP_PUBLIC_BEARER_TOKEN=
