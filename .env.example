# HR AI Module Configuration

# OpenAI API Key (required for SMART evaluation and goal generation)
OPENAI_API_KEY=sk-your-api-key-here

# Database URL
# For SQLite (default, good for development):
DATABASE_URL=sqlite:///./hr_goals.db
# For PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/hr_goals

# ChromaDB settings
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION_NAME=vnd_documents

# OpenAI Model settings
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Application settings
DEBUG=true
APP_NAME=HR AI Module
APP_VERSION=1.0.0
